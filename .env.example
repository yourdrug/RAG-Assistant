# Скопируй в .env:  cp .env.example .env
# Читается docker-compose.yml автоматически (POSTGRES_*, DOMAIN, DOCKER_MTU).
# Настройки приложения — в server/.env (см. server/.env.example).

# --- PostgreSQL (для сервиса postgres в docker-compose.yml) ---
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword

# --- HTTPS (Caddy) ---
# Раскомментируй для домена (task up:public):
DOMAIN=rag.example.com
ACME_EMAIL=postmaster@example.com

# --- Docker-сеть ---
# Снижай до 1400 если на хосте VPN (иначе рвутся TLS-пакеты)
DOCKER_MTU=1500
