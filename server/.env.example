# Скопируй в server/.env и поправь под себя:  cp server/.env.example server/.env
# docker-compose.yaml подключает этот файл сервису server через env_file.

# --- Postgres ---
# Креды совпадают с захардкоженными в docker-compose.yaml (сервис postgres).
# Если меняешь пароль там — поменяй и здесь.
DATABASE_URL=postgresql://raguser:ragpassword@postgres:5432/ragdb

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=company_docs

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
# qwen2.5:14b (Apache-2.0) — по умолчанию. Альтернатива: mistral-nemo:12b (Apache-2.0)
LLM_MODEL=qwen2.5:14b

# --- Эмбеддинги и реранкер (лицензионно безопасный набор) ---
EMBED_MODEL=BAAI/bge-m3                 # MIT
RERANK_MODEL=BAAI/bge-reranker-v2-m3    # MIT
RERANK_DEVICE=cpu                       # cuda — если есть NVIDIA GPU

# --- OCR сканов в PDF ---
OCR_ENABLED=true
OCR_ENGINE=paddleocr    # paddleocr | surya | auto (surya — отдельная установка, см. README)
OCR_LANG_PADDLE=ru
