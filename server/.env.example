# Скопируй в server/.env:  cp server/.env.example server/.env
# Переменные Postgres, Caddy, Docker-сети — в корневом .env (см. .env.example).

# ===========================================================================
# PostgreSQL
# ===========================================================================
# Креды совпадают с .env (сервис postgres). URL для подключения внутри контейнера.
DATABASE_URL=postgresql://raguser:ragpassword@postgres:5432/ragdb

# ===========================================================================
# Qdrant
# ===========================================================================
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=company_docs

# ===========================================================================
# Ollama (LLM)
# ===========================================================================
OLLAMA_BASE_URL=http://ollama:11434
# qwen2.5:14b (Apache-2.0) — лучший баланс русского языка и качества.
# Альтернатива: mistral-nemo:12b (Apache-2.0), qwen2.5:7b (лёгкая).
LLM_MODEL=qwen2.5:14b

# ===========================================================================
# Эмбеддинги и реранкер (лицензионно безопасный набор, MIT)
# ===========================================================================
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cpu                       # cuda — если есть NVIDIA GPU

# ===========================================================================
# OCR (для сканов внутри PDF)
# ===========================================================================
OCR_ENABLED=true
# paddleocr (по умолчанию) — Apache-2.0, без ограничений.
# surya — точнее на сложной вёрстке, НО отдельная лицензия (см. README).
# auto — сначала PaddleOCR, если не дал текста — surya (если включён).
OCR_ENGINE=paddleocr
OCR_LANG_PADDLE=ru                      # ru | en | ...

# ===========================================================================
# Авторизация (JWT)
# ===========================================================================
# ОБЯЗАТЕЛЬНО смени в проде — openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440                 # 24 часа

# Bootstrap-админ (создаётся при первом запуске, если задан)
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# ===========================================================================
# Файловое хранилище
# ===========================================================================
# local — файлы в DATA_DIR/docs_sample (по умолчанию)
# s3    — S3-совместимое хранилище (MinIO, AWS S3 и т.п.)
FILE_BACKEND=local

# S3 / MinIO (используется при FILE_BACKEND=s3)
# Для AWS S3: S3_ENDPOINT=https://s3.amazonaws.com (или оставить пустым)
# Для MinIO:  S3_ENDPOINT=http://minio:9000
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_REGION=eu-central-1

# ===========================================================================
# Приложение
# ===========================================================================
# Корневая директория данных (внутри контейнера — /code/project/data)
DATA_DIR=/code/project/data

# CORS — список доменов через запятую, * = разрешить всё
ALLOWED_ORIGINS=*
